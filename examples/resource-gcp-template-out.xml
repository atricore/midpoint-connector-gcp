<resource xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
          xmlns:c="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
          xmlns:icfs="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/resource-schema-3"
          xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
          xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
          xmlns:ri="http://midpoint.evolveum.com/xml/ns/public/resource/instance-3"
          xmlns:t="http://prism.evolveum.com/xml/ns/public/types-3"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          oid="10000000-0000-0000-0001-000000000199">
    <name>GCP : Project Template (OUTBOUND)</name>
    <description>GCP Project Template - OUTBOUND</description>
    <documentation>
        # GCP Project Resource Template for Google Managed permissions

        This template provides the base configuration for connecting to GCP projects. It defines:

        1. **Connector Configuration**: Uses the Google Cloud Connector to connect to GCP
        2. **Schema Handling**: Maps GCP objects to midPoint objects
        - GCP Roles → midPoint Roles (entitlement/group)
        - GWS Groups → midPoint Roles (account/GWSGroup)
        - GWS Accounts → midPoint Users (account/GWSAccount)
        3. **Associations**: Defines relationships between different object types
        4. **Capabilities**: Configures what operations are supported

        ## Usage Instructions

        To create a resource for a specific GCP project:

        1. Create a new resource XML that extends this template
        2. Override the project ID and other specific configuration
        3. Configure synchronization tasks to import roles and accounts

        ## Synchronization Process

        - **Import**: Scheduled tasks bring GCP roles and accounts into midPoint
        - **Export**: Assignments in midPoint are propagated to GCP

    </documentation>

    <abstract>true</abstract>
    <template>true</template>

    <connectorRef relation="org:default" type="c:ConnectorType">
        <filter>
            <q:text>c:connectorType = "com.atricore.iam.midpoint.connector.gcp.GoogleCloudConnector" and c:connectorVersion = "1.3.0-SNAPSHOT"</q:text>
        </filter>
    </connectorRef>

    <connectorConfiguration xmlns:icfc="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/connector-schema-3">
        <icfc:resultsHandlerConfiguration>
            <icfc:enableFilteredResultsHandler>false</icfc:enableFilteredResultsHandler>
        </icfc:resultsHandlerConfiguration>
        <icfc:configurationProperties
                xmlns:icfcga="http://midpoint.evolveum.com/xml/ns/public/connector/icf-1/bundle/com.atricore.iam.evolveum.connetor.connector-gcp/com.atricore.iam.midpoint.connector.gcp.GoogleCloudConnector">
            <icfcga:orgId>1234567890123</icfcga:orgId>
            <icfcga:project>my-gcp-project</icfcga:project>
            <icfcga:serviceAccountKeyJson>
                <t:clearValue>{
                   .....
                    }</t:clearValue>
            </icfcga:serviceAccountKeyJson>
            <icfcga:backupPolicy>false</icfcga:backupPolicy>
            <icfcga:backupPolicyLocation>/opt/midpoint/var/bkp</icfcga:backupPolicyLocation>
            <!-- 30 secs -->
            <icfcga:maxCacheTTL>30000</icfcga:maxCacheTTL>
            <icfcga:allowCache>true</icfcga:allowCache>
        </icfc:configurationProperties>
    </connectorConfiguration>

    <schemaHandling>

        <!-- entitlement/group -->
        <objectType>

            <kind>entitlement</kind>
            <intent>group</intent>
            <default>true</default>

            <objectClass>ri:GCPRole</objectClass>
            <displayName>GCP Role</displayName>

            <focus>
                <type>c:RoleType</type>
            </focus>

            <!-- icfs:name -->
            <attribute>
                <ref>icfs:name</ref>
                <displayName>Name (icfs)</displayName>

                <inbound>
                    <name>get-name</name>
                    <strength>weak</strength>
                    <source>
                        <path>$shadow/name</path>
                    </source>
                    <expression>
                        <script>
                            <code>
                                project = basic.getResourceIcfConfigurationPropertyValue(resource, 'project')
                                return "GCP:" + project + ":" + name
                            </code>
                        </script>
                    </expression>
                    <target>
                        <path>$focus/name</path>
                    </target>
                </inbound>

                <inbound>
                    <name>get-identifier</name>
                    <strength>weak</strength>
                    <source>
                        <path>$shadow/name</path>
                    </source>
                    <expression>
                        <script>
                            <code>
                                project = basic.getResourceIcfConfigurationPropertyValue(resource, 'project')
                                return "GCP:" + project + ":" + name
                            </code>
                        </script>
                    </expression>
                    <target>
                        <path>$focus/identifier</path>
                    </target>
                </inbound>

            </attribute>

            <!-- description -->
            <attribute>
                <ref>description</ref>
                <displayName>Description</displayName>
                <inbound>
                    <name>get-description</name>
                    <strength>weak</strength>
                    <target>
                        <path>$focus/description</path>
                    </target>
                </inbound>
            </attribute>

            <!-- displayName -->
            <attribute>
                <ref>ri:title</ref>
                <displayName>Title</displayName>
                <inbound>
                    <name>get-title</name>
                    <strength>strong</strength>
                    <source>
                        <path>$shadow/attributes/ri:title</path>
                    </source>
                    <expression>
                        <script>
                            <code>
                                project = basic.getResourceIcfConfigurationPropertyValue(resource, 'project')
                                return title + " (" + project + ")"
                            </code>
                        </script>
                    </expression>
                    <target>
                        <path>$focus/displayName</path>
                    </target>
                </inbound>
            </attribute>

            <!-- costCenter -->
            <attribute>
                <ref>ri:project</ref>
                <displayName>Project</displayName>
                <inbound>
                    <name>get-project</name>
                    <strength>weak</strength>
                    <target>
                        <path>$focus/costCenter</path>
                    </target>
                </inbound>
            </attribute>

            <!-- correlate using name -->

            <synchronization>
                <reaction>
                    <situation>linked</situation>
                    <actions>
                        <synchronize/>
                    </actions>
                </reaction>
                <reaction>
                    <situation>deleted</situation>
                    <actions>
                        <deleteFocus/>
                    </actions>
                </reaction>
                <reaction>
                    <situation>unlinked</situation>
                    <actions>
                        <link/>
                    </actions>
                </reaction>
                <reaction>
                    <situation>unmatched</situation>
                    <actions>
                        <addFocus/>
                    </actions>
                </reaction>
            </synchronization>

            <configuredCapabilities xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">

                <!-- can't manage GCP Roles activation -->
                <cap:activation>
                    <cap:enabled>false</cap:enabled>
                </cap:activation>

                <!-- can't create GCP Roles -->
                <cap:create>
                    <cap:enabled>false</cap:enabled>
                </cap:create>

                <cap:read>
                    <cap:enabled>true</cap:enabled>
                </cap:read>

                <cap:update>
                    <cap:enabled>true</cap:enabled>
                    <cap:addRemoveAttributeValues>false</cap:addRemoveAttributeValues>
                </cap:update>

                <!-- can't delete GCP roles -->
                <cap:delete>
                    <cap:enabled>false</cap:enabled>
                </cap:delete>

                <cap:script>
                    <cap:enabled>false</cap:enabled>
                    <cap:host>
                        <cap:type>connector</cap:type>
                    </cap:host>
                </cap:script>

            </configuredCapabilities>

            <projection>
                <assignmentPolicyEnforcement>none</assignmentPolicyEnforcement>
            </projection>

        </objectType>

        <!-- account/GWSGroup -->
        <objectType>
            <kind>account</kind>
            <intent>GWSGroup</intent>
            <objectClass>ri:GWSGroup</objectClass>
            <displayName>GWS Group</displayName>
            <focus>
                <type>c:RoleType</type>
                <!-- You can also filter based on RoleType archetype: -->
                <!-- archetypeRef oid="00000000-0000-0001-0328-000000000141" relation="org:default" type="c:ArchetypeType"/-->
            </focus>

            <!-- icfs:name -->
            <attribute>

                <ref>icfs:name</ref>
                <displayName>Name (icfs)</displayName>
                <correlator/>
                <inbound>
                    <name>get-name</name>
                    <strength>weak</strength>
                    <source>
                        <path>$projection/attributes/name</path>
                    </source>
                    <expression>
                        <script>
                            <code>name.toLowerCase()</code>
                        </script>
                    </expression>
                    <target>
                        <path>$focus/name</path>
                    </target>
                </inbound>

                <outbound>
                    <name>set-name</name>
                    <strength>weak</strength>
                    <source>
                        <path>$focus/name</path>
                    </source>
                </outbound>
                <correlator/>
            </attribute>

            <synchronization>
                <reaction>
                    <situation>linked</situation>
                    <actions>
                        <synchronize/>
                    </actions>
                </reaction>

                <reaction>
                    <situation>unmatched</situation>
                    <actions>
                        <addFocus/>
                    </actions>
                </reaction>

                <reaction>
                    <situation>deleted</situation>
                    <actions>
                        <deleteFocus/>
                    </actions>
                </reaction>

                <reaction>
                    <situation>unlinked</situation>
                    <actions>
                        <link/>
                    </actions>
                </reaction>

            </synchronization>

            <configuredCapabilities xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
                <!-- can't activate GWS Groups -->
                <cap:activation>
                    <cap:enabled>false</cap:enabled>
                </cap:activation>

                <!-- can't manage GWS Groups credentials -->
                <cap:credentials>
                    <cap:enabled>false</cap:enabled>
                </cap:credentials>

                <cap:create>
                    <cap:enabled>true</cap:enabled>
                </cap:create>

                <cap:read>
                    <cap:enabled>true</cap:enabled>
                </cap:read>

                <cap:update>
                    <cap:enabled>true</cap:enabled>
                    <!-- can't update individual GWS Role attributes -->
                    <cap:addRemoveAttributeValues>false</cap:addRemoveAttributeValues>
                </cap:update>

                <cap:delete>
                    <cap:enabled>false</cap:enabled>
                </cap:delete>

                <!-- can't execute GWS Groups scripts -->
                <cap:script>
                    <cap:enabled>false</cap:enabled>
                    <cap:host>
                        <cap:type>connector</cap:type>
                    </cap:host>
                </cap:script>

            </configuredCapabilities>

        </objectType>

        <!-- account/GWSAccount -->
        <objectType>
            <kind>account</kind>
            <intent>GWSAccount</intent>
            <objectClass>ri:GWSAccount</objectClass>
            <displayName>GWS Account</displayName>
            <focus>
            <type>c:UserType</type>
                <!-- You can also filter based on UserType archetype: -->
                <!-- archetypeRef oid="00000000-0000-0001-0328-000000000141" relation="org:default" type="c:ArchetypeType"/-->
            </focus>

            <!-- icfs:name -->
            <attribute>

                <ref>icfs:name</ref>
                <displayName>Name (icfs)</displayName>
                <correlator/>
                <inbound>
                    <name>get-name</name>
                    <strength>weak</strength>
                    <source>
                        <path>$projection/attributes/name</path>
                    </source>
                    <expression>
                        <script>
                            <code>name.toLowerCase()</code>
                        </script>
                    </expression>
                    <target>
                        <path>$focus/name</path>
                    </target>
                </inbound>

                <outbound>
                    <name>set-name</name>
                    <strength>weak</strength>
                    <source>
                        <path>$focus/name</path>
                    </source>
                </outbound>
                <correlator/>
            </attribute>

            <synchronization>
                <reaction>
                    <situation>linked</situation>
                    <actions>
                        <synchronize/>
                    </actions>
                </reaction>

                <reaction>
                    <situation>unmatched</situation>
                    <actions>
                        <addFocus/>
                    </actions>
                </reaction>

                <reaction>
                    <situation>deleted</situation>
                    <actions>

                    </actions>
                </reaction>

                <reaction>
                    <situation>unlinked</situation>
                    <actions>
                        <link/>
                    </actions>
                </reaction>
            </synchronization>

            <configuredCapabilities xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
                <!-- can't activate GWS Groups -->
                <cap:activation>
                    <cap:enabled>false</cap:enabled>
                </cap:activation>

                <!-- can't manage GWS Groups credentials -->
                <cap:credentials>
                    <cap:enabled>false</cap:enabled>
                </cap:credentials>

                <cap:create>
                    <cap:enabled>true</cap:enabled>
                </cap:create>

                <cap:read>
                    <cap:enabled>true</cap:enabled>
                </cap:read>

                <cap:update>
                    <cap:enabled>true</cap:enabled>
                    <!-- can't update individual GWS Role attributes -->
                    <cap:addRemoveAttributeValues>false</cap:addRemoveAttributeValues>
                </cap:update>

                <cap:delete>
                    <cap:enabled>false</cap:enabled>
                </cap:delete>

                <!-- can't execute GWS Groups scripts -->
                <cap:script>
                    <cap:enabled>false</cap:enabled>
                    <cap:host>
                        <cap:type>connector</cap:type>
                    </cap:host>
                </cap:script>

            </configuredCapabilities>

        </objectType>

        <!-- account/GCP Service Account -->
        <objectType>
            <kind>account</kind>
            <intent>GCPServiceAccount</intent>
            <objectClass>ri:GCPServiceAccount</objectClass>
            <displayName>GCP Service Account</displayName>

            <focus>
                <type>c:AccountType</type>
                <!-- TODO archetypeRef oid="00000000-0000-0001-0328-000000000141" relation="org:default" type="c:ArchetypeType"/-->
            </focus>

        </objectType>

        <!-- ROLE/GWS Group -->
        <associationType>
            <name>roleToGWSGroup</name>
            <subject>
                <objectType>
                    <kind>account</kind>
                    <intent>GWSGroup</intent>
                </objectType>
                <association>
                    <ref>ri:__GROUPS__</ref>
                    <tolerant>false</tolerant>

                    <outbound>
                        <name>role-assignments-to-gws-group-membership</name>
                        <strength>strong</strength>
                        <lifecycleState>active</lifecycleState>
                        <expression>
                            <associationConstruction xsi:type="c:AssociationConstructionExpressionEvaluatorType">
                                <objectRef>

                                    <ref>ri:__GROUPS__</ref>
                                    <mapping>
                                        <name>associationFromLink</name>
                                        <strength>strong</strength>
                                        <expression>
                                            <associationFromLink>

                                            </associationFromLink>
                                        </expression>
                                    </mapping>
                                </objectRef>
                            </associationConstruction>
                        </expression>
                    </outbound>

                    <inbound>
                        <name>group-membership-to-role-assignments</name>
                        <!-- set this to strong, to import from GCP -->
                        <lifecycleState>active</lifecycleState>
                        <strength>weak</strength>
                        <expression>
                            <associationSynchronization xsi:type="c:AssociationSynchronizationExpressionEvaluatorType">
                                <objectRef>
                                    <ref>ri:__GROUPS__</ref>
                                    <mapping>
                                        <name>shadowOwner-into-targetRef</name>
                                        <strength>strong</strength>
                                        <expression>
                                            <shadowOwnerReferenceSearch/>
                                        </expression>
                                        <target>
                                            <path>targetRef</path>
                                        </target>
                                    </mapping>
                                </objectRef>
                                <correlation>
                                    <correlators>
                                        <items>
                                            <name>membership-correlation</name>
                                            <enabled>true</enabled>
                                            <item>
                                                <ref>targetRef</ref>
                                            </item>
                                        </items>
                                    </correlators>
                                </correlation>
                                <synchronization>
                                    <reaction>
                                        <name>unmatched-add</name>
                                        <situation>unmatched</situation>
                                        <actions>
                                            <addFocusValue/>
                                        </actions>
                                    </reaction>
                                    <reaction >
                                        <name>matched-synchronize</name>
                                        <situation>matched</situation>
                                        <actions>
                                            <synchronize/>
                                        </actions>
                                    </reaction>
                                    <reaction>
                                        <name>indirectly-matched-ignore</name>
                                        <situation>matchedIndirectly</situation>
                                    </reaction>
                                </synchronization>
                            </associationSynchronization>
                        </expression>
                    </inbound>

                </association>
            </subject>
            <object>
                <objectType>
                    <kind>entitlement</kind>
                    <intent>group</intent>
                </objectType>
            </object>
        </associationType>

        <!-- ROLE/GWS Account -->
        <associationType>
            <name>roleToGWSAccount</name>
            <subject>
                <objectType>
                    <kind>account</kind>
                    <intent>GWSAccount</intent>
                </objectType>

                <association>
                    <ref>ri:__GROUPS__</ref>
                    <tolerant>false</tolerant>

                    <outbound>
                        <name>role-assignments-to-gws-account-membership</name>
                        <strength>strong</strength>
                        <lifecycleState>active</lifecycleState>
                        <expression>
                            <associationConstruction xsi:type="c:AssociationConstructionExpressionEvaluatorType">
                                <objectRef>
                                    <ref>ri:__GROUPS__</ref>
                                    <mapping>
                                        <name>associationFromLink</name>
                                        <strength>strong</strength>
                                        <expression>
                                            <associationFromLink>

                                            </associationFromLink>
                                        </expression>
                                    </mapping>
                                </objectRef>
                            </associationConstruction>
                        </expression>
                    </outbound>

                    <inbound>
                        <name>account-membership-to-role-assignments</name>
                        <lifecycleState>active</lifecycleState>
                        <strength>weak</strength>
                        <expression>
                            <associationSynchronization xsi:type="c:AssociationSynchronizationExpressionEvaluatorType">
                                <objectRef>
                                    <ref>ri:__GROUPS__</ref>
                                    <mapping>
                                        <name>shadowOwner-into-targetRef</name>
                                        <strength>strong</strength>
                                        <expression>
                                            <shadowOwnerReferenceSearch/>
                                        </expression>
                                        <target>
                                            <path>targetRef</path>
                                        </target>
                                    </mapping>
                                </objectRef>
                                <correlation>
                                    <correlators>
                                        <items>
                                            <name>membership-correlation</name>
                                            <enabled>true</enabled>
                                            <item>
                                                <ref>targetRef</ref>
                                            </item>
                                        </items>
                                    </correlators>
                                </correlation>
                                <synchronization>
                                    <reaction>
                                        <name>unmatched-add</name>
                                        <situation>unmatched</situation>
                                        <actions>
                                            <addFocusValue/>
                                        </actions>
                                    </reaction>
                                    <reaction >
                                        <name>matched-synchronize</name>
                                        <situation>matched</situation>
                                        <actions>
                                            <synchronize/>
                                        </actions>
                                    </reaction>
                                    <reaction>
                                        <name>indirectly-matched-ignore</name>
                                        <situation>matchedIndirectly</situation>
                                    </reaction>
                                </synchronization>
                            </associationSynchronization>
                        </expression>
                    </inbound>

                </association>

            </subject>

            <object>
                <objectType>
                    <kind>entitlement</kind>
                    <intent>group</intent>
                </objectType>
            </object>

        </associationType>

    </schemaHandling>

    <capabilities>
        <native xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
            <cap:schema/>

            <cap:create/>

            <cap:read>
                <cap:returnDefaultAttributesOption>false</cap:returnDefaultAttributesOption>
            </cap:read>

            <cap:update>
                <cap:addRemoveAttributeValues>true</cap:addRemoveAttributeValues>
            </cap:update>

            <cap:testConnection/>

            <cap:script>
                <cap:host>
                    <cap:type>connector</cap:type>
                </cap:host>
            </cap:script>

            <cap:pagedSearch/>
        </native>

        <configured xmlns:cap="http://midpoint.evolveum.com/xml/ns/public/resource/capabilities-3">
            <cap:references>
                <!-- GROUPS to ROLES -->
                <cap:type>
                    <cap:name>ri:roleToGWSGroup</cap:name>
                    <cap:subject>
                        <cap:delineation>
                            <cap:objectClass>ri:GWSGroup</cap:objectClass>
                        </cap:delineation>
                        <cap:primaryBindingAttributeRef>icfs:name</cap:primaryBindingAttributeRef>
                        <cap:secondaryBindingAttributeRef>icfs:groups</cap:secondaryBindingAttributeRef>
                        <cap:localItemName>ri:__GROUPS__</cap:localItemName>
                    </cap:subject>

                    <cap:object>
                        <cap:delineation>
                            <cap:objectClass>ri:GCPRole</cap:objectClass>
                        </cap:delineation>

                        <cap:primaryBindingAttributeRef>ri:GROUPS</cap:primaryBindingAttributeRef>
                        <cap:secondaryBindingAttributeRef>icfs:name</cap:secondaryBindingAttributeRef>
                    </cap:object>

                    <cap:explicitReferentialIntegrity>true</cap:explicitReferentialIntegrity>
                    <cap:direction>objectToSubject</cap:direction>
                </cap:type>

                <!-- ACCOUNT to ROLES -->
                <cap:type>
                    <cap:name>ri:roleToGWSAccount</cap:name>
                    <cap:subject>
                        <cap:delineation>
                            <cap:objectClass>ri:GWSAccount</cap:objectClass>
                        </cap:delineation>
                        <cap:primaryBindingAttributeRef>icfs:name</cap:primaryBindingAttributeRef>
                        <cap:secondaryBindingAttributeRef>icfs:groups</cap:secondaryBindingAttributeRef>
                        <cap:localItemName>ri:__GROUPS__</cap:localItemName>
                    </cap:subject>

                    <cap:object>
                        <cap:delineation>
                            <cap:objectClass>ri:GCPRole</cap:objectClass>
                        </cap:delineation>
                        <cap:primaryBindingAttributeRef>ri:USERS</cap:primaryBindingAttributeRef>
                        <cap:secondaryBindingAttributeRef>icfs:name</cap:secondaryBindingAttributeRef>
                    </cap:object>

                    <cap:explicitReferentialIntegrity>true</cap:explicitReferentialIntegrity>
                    <cap:direction>objectToSubject</cap:direction>
                </cap:type>

            </cap:references>
        </configured>

    </capabilities>

</resource>
